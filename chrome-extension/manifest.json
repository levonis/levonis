{
  "manifest_version": 3,
  "name": "Levonis Store Helper",
  "version": "1.0.0",
  "description": "إرسال منتجات Amazon/Newegg إلى Levonis بضغطة واحدة",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "*://*.amazon.com/*",
    "*://*.amazon.ae/*",
    "*://*.newegg.com/*",
    "*://*.bestbuy.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.amazon.com/*",
        "*://*.amazon.ae/*",
        "*://*.newegg.com/*",
        "*://*.bestbuy.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}
